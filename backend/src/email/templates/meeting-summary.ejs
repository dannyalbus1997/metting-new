<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>Meeting Summary Report</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');
    * { margin:0; padding:0; box-sizing:border-box; }
    body, table, td { font-family:'Outfit', Arial, Helvetica, sans-serif; }
    body { margin:0 !important; padding:0 !important; width:100% !important; background-color:#FFF5F0; }
    table { border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { border:0; display:block; max-width:100%; }
    a { text-decoration:none; }

    @keyframes fadeUp  { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @keyframes barFill { from{width:0%} to{width:85%} }
    @keyframes shimmer { 0%,100%{opacity:.85} 50%{opacity:1} }

    .a1{animation:fadeUp .5s ease .05s both}
    .a2{animation:fadeUp .5s ease .15s both}
    .a3{animation:fadeUp .5s ease .25s both}
    .a4{animation:fadeUp .5s ease .35s both}
    .a5{animation:fadeUp .5s ease .45s both}
    .a6{animation:fadeUp .5s ease .55s both}
    .a7{animation:fadeUp .5s ease .65s both}
    .bar{animation:barFill 1.6s cubic-bezier(.4,0,.2,1) .9s both; width:0%}
    .shimmer{animation:shimmer 3s ease-in-out infinite}

    @media only screen and (max-width:620px) {
      .main { width:100% !important; }
      .ht   { font-size:36px !important; line-height:1.1 !important; }
      .p44  { padding:22px 18px !important; }
      .p36  { padding:20px 16px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#FFF5F0;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" bgcolor="#FFF5F0">
<tr><td align="center" style="padding:36px 12px 24px;">

<table role="presentation" class="main" width="600" cellpadding="0" cellspacing="0" style="width:600px;max-width:600px;">


<!-- ══════════════════════════════════════════
     HERO — UNTOUCHED
══════════════════════════════════════════ -->
<tr><td class="a1">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0"
       style="background:linear-gradient(145deg,#FF6B35 0%,#FF8E53 30%,#FFAA65 55%,#FFCC70 80%,#FFE099 100%);
              border-radius:24px 24px 0 0;overflow:hidden;">

  <tr><td style="background:linear-gradient(90deg,#FF4D6D,#FF8E53,#FFCC70,#56CFE1,#9B5DE5);height:5px;font-size:1px;line-height:1px;">&nbsp;</td></tr>

  <tr><td class="p44" style="padding:44px 44px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td valign="top" style="width:58%;padding-right:12px;">
          <table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom:18px;">
            <tr><td style="background:rgba(255,255,255,0.28);border:1.5px solid rgba(255,255,255,0.55);border-radius:100px;padding:5px 16px;white-space:nowrap;">
              <span style="font-family:'Outfit',Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:#fff;">Internal · Q2 2026</span>
            </td></tr>
          </table>
          <div class="ht" style="font-family:'Outfit',Arial,sans-serif;font-size:46px;font-weight:800;line-height:1.06;color:#fff;letter-spacing:-.03em;">Meeting<br><span style="color:rgba(255,255,255,0.55);font-size:28px;font-weight:700;">Summary</span><br>Report</div>
          <table role="presentation" cellpadding="0" cellspacing="0" style="margin-top:22px;">
            <tr><td style="padding-bottom:8px;">
              <span style="display:inline-block;background:rgba(255,255,255,0.22);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;color:#fff;">📅 <%= dateStr %> · <%= timeStr %>–<%= endTimeStr %></span>
            </td></tr>
            <tr><td>
              <span style="display:inline-block;background:rgba(255,255,255,0.22);border-radius:8px;padding:6px 14px;font-size:12px;font-weight:600;color:#fff;">📍 Board Room A & Remote</span>
            </td></tr>
          </table>
        </td>
        <td valign="bottom" style="width:42%;text-align:right;padding-bottom:0;">
          <div style="font-size:48px;text-align:right;line-height:.8;">📊</div>
        </td>
      </tr>
    </table>
  </td></tr>

  <!-- bottom gradient strip with white space for summary text -->
  <tr><td style="background:rgba(255,255,255,0.08);padding:32px 44px 44px;">

    <!-- Summary text section -->
    <div style="background:rgba(255,255,255,0.85);border-radius:16px;padding:24px 20px;">
      <div style="font-size:12px;color:#B09080;margin-bottom:2px;text-transform:uppercase;letter-spacing:.1em;font-weight:700;">Session Summary</div>
      <div style="font-size:15px;line-height:1.75;color:#3D2817;margin-top:8px;"><%- summary %></div>
    </div>

  </td></tr>
</table>
</td></tr>

<!-- ══════════════════════════════════════════
     SESSION OVERVIEW & STATS
══════════════════════════════════════════ -->
<tr><td class="a2" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:20px;overflow:hidden;border:1px solid #F0E8E0;">

  <!-- gradient top strip -->
  <tr><td style="background:linear-gradient(90deg,#FF4D6D,#FF8E53,#FFCC70);height:4px;font-size:1px;">&nbsp;</td></tr>

  <tr><td style="padding:28px 32px;">

    <!-- title row with session name & duration -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td valign="middle">
          <div style="font-family:'Outfit',Arial,sans-serif;font-size:20px;font-weight:800;color:#1A0A00;letter-spacing:-.02em;"><%= title %></div>
          <div style="font-size:12px;color:#B09080;margin-top:2px;"><% if(durationMin) { %><%= durationMin %> min session<% } %></div>
        </td>
        <td align="right" valign="middle">
          <span style="display:inline-block;background:linear-gradient(135deg,#FFF3E0,#FFF8F0);border:1.5px solid #FFB347;border-radius:10px;padding:6px 14px;font-size:11px;font-weight:700;color:#E07B00;"><%= participantCount %> attendees</span>
        </td>
      </tr>
    </table>

    <!-- 4 stat tiles in a row -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
      <tr>
        <!-- tile 1 -->
        <td width="130" style="padding-right:8px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(145deg,#FFF5EE,#FFF0E6);border-radius:16px;border:1px solid #FFD6B0;overflow:hidden;">
            <tr><td style="background:linear-gradient(90deg,#FF6B35,#FF8E53);height:3px;font-size:1px;">&nbsp;</td></tr>
            <tr><td style="padding:16px 14px;">
              <div style="font-size:22px;margin-bottom:4px;">📋</div>
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:15px;font-weight:800;color:#C84B00;line-height:1.1;"><%= title.substring(0, 12) %></div>
              <div style="font-size:10px;color:#C08060;margin-top:4px;font-weight:500;">MEETING TYPE</div>
            </td></tr>
          </table>
        </td>
        <!-- tile 2 -->
        <td width="130" style="padding-right:8px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(145deg,#F5F0FF,#EEE8FF);border-radius:16px;border:1px solid #CDB8F8;overflow:hidden;">
            <tr><td style="background:linear-gradient(90deg,#9B5DE5,#B47CF0);height:3px;font-size:1px;">&nbsp;</td></tr>
            <tr><td style="padding:16px 14px;">
              <div style="font-size:22px;margin-bottom:4px;">👤</div>
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:15px;font-weight:800;color:#5A1DAF;line-height:1.1;"><% if(participants.length > 0) { %><%= participants[0].displayName.split(' ').slice(0, 1).join(' ') %><% } %></div>
              <div style="font-size:10px;color:#8060B0;margin-top:4px;font-weight:500;">FACILITATOR</div>
            </td></tr>
          </table>
        </td>
        <!-- tile 3 -->
        <td width="130" style="padding-right:8px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(145deg,#E8FAFA,#D8F5F8);border-radius:16px;border:1px solid #A0DDE6;overflow:hidden;">
            <tr><td style="background:linear-gradient(90deg,#0CBBCC,#56CFE1);height:3px;font-size:1px;">&nbsp;</td></tr>
            <tr><td style="padding:16px 14px;">
              <div style="font-size:22px;margin-bottom:4px;">🏛️</div>
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:15px;font-weight:800;color:#007A8A;line-height:1.1;">Room A</div>
              <div style="font-size:10px;color:#408090;margin-top:4px;font-weight:500;">LOCATION</div>
            </td></tr>
          </table>
        </td>
        <!-- tile 4 -->
        <td width="130">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(145deg,#EDFFF5,#D8FAE8);border-radius:16px;border:1px solid #90DDB0;overflow:hidden;">
            <tr><td style="background:linear-gradient(90deg,#10B981,#34D399);height:3px;font-size:1px;">&nbsp;</td></tr>
            <tr><td style="padding:16px 14px;">
              <div style="font-size:22px;margin-bottom:4px;">✅</div>
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:15px;font-weight:800;color:#047857;line-height:1.1;">Completed</div>
              <div style="font-size:10px;color:#3A9060;margin-top:4px;font-weight:500;">OUTCOME</div>
            </td></tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- Key decisions — magazine style -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr><td style="background:linear-gradient(135deg,#FFFAF5 0%,#FFF5FF 50%,#F5F8FF 100%);border-radius:18px;padding:24px 26px;border:1px solid #F0DDD0;">

        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:18px;">
          <tr>
            <td valign="middle">
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:14px;font-weight:800;color:#1A0A00;">Key Decisions Made</div>
            </td>
            <td align="right" valign="middle">
              <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#FF6B35,#FFCC70);text-align:center;line-height:28px;font-family:'Outfit',Arial,sans-serif;font-size:12px;font-weight:800;color:#fff;"><%= decisions.length %></div>
            </td>
          </tr>
        </table>

        <% decisions.forEach(function(decision, index) { %>
        <!-- decision <%= index + 1 %> -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" <% if(index < decisions.length - 1) { %>style="margin-bottom:14px;"<% } %>>
          <tr>
            <td width="36" valign="top">
              <div style="width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,<% if(index % 3 === 0) { %>#FF6B35,#FF4D6D<% } else if(index % 3 === 1) { %>#9B5DE5,#56CFE1<% } else { %>#FFCC70,#FF8E53<% } %>);text-align:center;line-height:32px;font-family:'Outfit',Arial,sans-serif;font-size:13px;font-weight:800;color:#fff;"><%= index + 1 %></div>
            </td>
            <td style="padding-left:12px;vertical-align:top;">
              <div style="font-size:13px;font-weight:600;color:#2D1810;margin-bottom:2px;"><% if(typeof decision === 'object') { %><%= decision.title %><% } else { %><%= decision %><% } %></div>
              <% if(typeof decision === 'object' && decision.description) { %>
              <div style="font-size:12px;color:#9A7060;line-height:1.6;"><%- decision.description %></div>
              <% } %>
            </td>
          </tr>
        </table>
        <% }); %>

      </td></tr>
    </table>

  </td></tr>
</table>
</td></tr>


<!-- ══════════════════════════════════════════
     PRODUCTIVITY SCORE — redesigned
══════════════════════════════════════════ -->
<% if(productivity) { %>
<tr><td class="a3" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-radius:20px;overflow:hidden;">

  <!-- full-bleed gradient card -->
  <tr><td style="background:linear-gradient(130deg,#7C3AED 0%,#9B5DE5 35%,#C084FC 60%,#F0ABFC 100%);padding:36px 40px 32px;">

    <!-- header row -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
      <tr>
        <td valign="middle">
          <div style="font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:6px;">This Session</div>
          <div style="font-family:'Outfit',Arial,sans-serif;font-size:24px;font-weight:800;color:#fff;letter-spacing:-.02em;">Productivity Score</div>
        </td>
        <!-- Big score badge -->
        <td align="right" valign="middle">
          <table role="presentation" cellpadding="0" cellspacing="0"><tr>
            <td style="background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.35);border-radius:20px;padding:12px 20px;text-align:center;">
              <div style="font-family:'Outfit',Arial,sans-serif;font-size:52px;font-weight:800;color:#fff;line-height:1;"><%= Math.round(productivity.score) %></div>
              <div style="font-size:13px;font-weight:700;color:rgba(255,255,255,0.7);letter-spacing:.1em;">/ 100</div>
              <div style="margin-top:6px;background:rgba(255,255,255,0.2);border-radius:100px;padding:3px 12px;">
                <span style="font-size:10px;font-weight:700;color:#FFEE99;letter-spacing:.12em;"><%= productivity.label.toUpperCase() %></span>
              </div>
            </td>
          </tr></table>
        </td>
      </tr>
    </table>

    <!-- Progress bar -->
    <div style="background:rgba(255,255,255,0.18);border-radius:100px;height:16px;overflow:hidden;margin-bottom:10px;">
      <div class="bar" style="height:16px;width:<%= Math.min(productivity.score, 100) %>%;background:linear-gradient(90deg,#fff 0%,rgba(255,255,255,0.8) 100%);border-radius:100px;">&nbsp;</div>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
      <tr>
        <td><span style="font-size:10px;color:rgba(255,255,255,0.45);">0</span></td>
        <td align="center"><span style="font-size:10px;color:rgba(255,255,255,0.6);font-weight:600;">Productivity Assessment</span></td>
        <td align="right"><span style="font-size:10px;color:rgba(255,255,255,0.45);">100</span></td>
      </tr>
    </table>

    <!-- 3 sub tiles — white frosted -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <% if(productivity.breakdown && productivity.breakdown.length > 0) { %>
          <% productivity.breakdown.forEach(function(item, idx) { %>
            <td <% if(idx < productivity.breakdown.length - 1) { %>width="176" style="padding-right:8px;"<% } else { %>width="168"<% } %>>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.3);border-radius:16px;">
                <tr><td style="padding:18px 16px;text-align:center;">
                  <div style="font-size:24px;margin-bottom:6px;">
                    <% if(item.category.includes('Engagement')) { %>🙌<% } else if(item.category.includes('Agenda')) { %>📌<% } else if(item.category.includes('Clarity')) { %>💡<% } else { %>📊<% } %>
                  </div>
                  <div style="font-family:'Outfit',Arial,sans-serif;font-size:30px;font-weight:800;color:#fff;line-height:1;"><%= Math.round(item.score) %>%</div>
                  <div style="font-size:10px;color:rgba(255,255,255,0.6);margin-top:5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;"><%= item.category %></div>
                </td></tr>
              </table>
            </td>
          <% }); %>
        <% } %>
      </tr>
    </table>

  </td></tr>
</table>
</td></tr>
<% } %>


<!-- ══════════════════════════════════════════
     ACTION ITEMS — redesigned
══════════════════════════════════════════ -->
<% if(actionItems && actionItems.length > 0) { %>
<tr><td class="a4" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:20px;overflow:hidden;border:1px solid #F0E8E0;">

  <!-- Warm gradient top -->
  <tr><td style="background:linear-gradient(90deg,#FF4D6D,#FF8E53,#FFCC70);height:4px;font-size:1px;">&nbsp;</td></tr>

  <tr><td style="padding:30px 36px 10px;">
    <!-- header -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:22px;">
      <tr>
        <td valign="middle">
          <div style="font-family:'Outfit',Arial,sans-serif;font-size:20px;font-weight:800;color:#1A0A00;letter-spacing:-.02em;">Action Items</div>
          <div style="font-size:12px;color:#B09080;margin-top:2px;"><%= actionItems.length %> tasks tracked</div>
        </td>
        <td align="right" valign="middle">
          <!-- status legend -->
          <table role="presentation" cellpadding="0" cellspacing="0">
            <tr>
              <td style="padding-right:10px;"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#10B981;margin-right:4px;vertical-align:middle;"></span><span style="font-size:11px;color:#9A7060;">High</span></td>
              <td style="padding-right:10px;"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#F59E0B;margin-right:4px;vertical-align:middle;"></span><span style="font-size:11px;color:#9A7060;">Medium</span></td>
              <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#F87171;margin-right:4px;vertical-align:middle;"></span><span style="font-size:11px;color:#9A7060;">Low</span></td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- Task cards — each task gets its own horizontal strip -->
    <% actionItems.forEach(function(item, idx) { %>
      <%
        var priorityColor = '#10B981';
        var priorityBg = '#EDFFF5';
        var priorityBgGradient = 'linear-gradient(90deg,#EDFFF5,#F5FFFA)';
        var priorityBorder = '#A8EDCC';
        var priorityGradient = 'linear-gradient(180deg,#10B981,#34D399)';
        var priorityText = '#064E3B';
        var priorityLabel = 'High';

        if(item.priority === 'medium' || item.priority === 'Medium') {
          priorityColor = '#F59E0B';
          priorityBg = '#FFFBEE';
          priorityBgGradient = 'linear-gradient(90deg,#FFFBEE,#FFF8E6)';
          priorityBorder = '#FCD68A';
          priorityGradient = 'linear-gradient(180deg,#F59E0B,#FBBF24)';
          priorityText = '#78350F';
          priorityLabel = 'Active';
        } else if(item.priority === 'low' || item.priority === 'Low') {
          priorityColor = '#EF4444';
          priorityBg = '#FFF5F5';
          priorityBgGradient = 'linear-gradient(90deg,#FFF5F5,#FFF0F0)';
          priorityBorder = '#FBBCBC';
          priorityGradient = 'linear-gradient(180deg,#EF4444,#F87171)';
          priorityText = '#7F1D1D';
          priorityLabel = 'Pending';
        }
      %>

      <!-- Task <%= idx + 1 %> -->
      <tr><td style="padding:0 24px <% if(idx === actionItems.length - 1) { %>24px<% } else { %>8px<% } %>;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:<%= priorityBgGradient %>;border-radius:14px;border:1px solid <%= priorityBorder %>;overflow:hidden;">
          <tr>
            <td width="5" style="background:<%= priorityGradient %>;font-size:1px;">&nbsp;</td>
            <td style="padding:14px 16px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
                <td valign="middle" width="220">
                  <div style="font-size:13px;font-weight:600;color:<%= priorityText %>;"><%= item.title %></div>
                  <div style="font-size:11px;color:<%= priorityColor %>;margin-top:2px;font-weight:500;">Owner: <%= item.assignee %></div>
                </td>
                <td valign="middle" align="center" width="90">
                  <div style="font-size:11px;color:<%= priorityColor %>;font-weight:600;">Due <%= item.dueDate %></div>
                </td>
                <td valign="middle" align="right">
                  <span style="display:inline-block;background:<%= priorityColor %>;border-radius:100px;padding:5px 14px;font-size:11px;font-weight:700;color:#fff;">
                    <% if(priorityLabel === 'High') { %>✓<% } else if(priorityLabel === 'Active') { %>●<% } else { %>○<% } %> <%= priorityLabel %>
                  </span>
                </td>
              </tr></table>
            </td>
          </tr>
        </table>
      </td></tr>
    <% }); %>

  </td></tr>
</table>
</td></tr>
<% } %>


<!-- ══════════════════════════════════════════
     ATTENDEES — 5-column compact list
══════════════════════════════════════════ -->
<% if(participants && participants.length > 0) { %>
<tr><td class="a5" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:20px;overflow:hidden;border:1px solid #F0E8E0;">

  <tr><td style="background:linear-gradient(90deg,#56CFE1,#9B5DE5,#FF4D6D);height:4px;font-size:1px;">&nbsp;</td></tr>

  <tr><td style="padding:28px 32px 28px;">

    <!-- header -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid #F5EDE6;">
      <tr>
        <td valign="middle">
          <div style="font-family:'Outfit',Arial,sans-serif;font-size:20px;font-weight:800;color:#1A0A00;letter-spacing:-.02em;">Attendees</div>
          <div style="font-size:12px;color:#B09080;margin-top:2px;"><%= participants.length %> participants · Hybrid meeting</div>
        </td>
        <td align="right" valign="middle">
          <span style="display:inline-block;background:linear-gradient(90deg,#FFF0E8,#F5EEFF);border:1.5px solid #E8D0F8;border-radius:100px;padding:5px 16px;font-size:11px;font-weight:700;color:#9B5DE5;"><%= participants.length %> people joined</span>
        </td>
      </tr>
    </table>

    <!-- Attendee rows (5 per row) -->
    <%
      var colors = [
        { initials: 'gradient(135deg,#FF6B35,#FF4D6D)', badge: '#FF6B35' },
        { initials: 'gradient(135deg,#9B5DE5,#56CFE1)', badge: '#9B5DE5' },
        { initials: 'gradient(135deg,#10B981,#56CFE1)', badge: '#10B981' },
        { initials: 'gradient(135deg,#F59E0B,#EF4444)', badge: '#F59E0B' },
        { initials: 'gradient(135deg,#3B82F6,#9B5DE5)', badge: '#3B82F6' },
        { initials: 'gradient(135deg,#FF4D6D,#FFCC70)', badge: '#FF4D6D' },
      ];

      function getInitials(displayName) {
        return displayName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
      }
    %>

    <% for(var row = 0; row < Math.ceil(participants.length / 5); row++) { %>
      <% if(row > 0) { %>
      <!-- Divider -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0;">
        <tr><td style="border-top:1px dashed #F0E0D8;font-size:1px;">&nbsp;</td></tr>
      </table>
      <% } %>

      <!-- Row <%= row + 1 %> -->
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" <% if(row > 0) { %>style="margin-bottom:8px;"<% } %>>
        <tr>
          <% for(var col = 0; col < 5; col++) { %>
            <% var idx = row * 5 + col; %>
            <% if(idx < participants.length) { %>
              <% var participant = participants[idx]; %>
              <% var color = colors[idx % colors.length]; %>
              <td width="104" valign="top" <% if(col < 4) { %>style="padding-right:6px;"<% } %>>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr><td align="center" style="padding-bottom:8px;">
                    <div style="width:44px;height:44px;border-radius:50%;background:linear-<%= color.initials %>;text-align:center;line-height:44px;font-family:'Outfit',Arial,sans-serif;font-size:12px;font-weight:800;color:#fff;margin:0 auto;"><%= getInitials(participant.displayName) %></div>
                  </td></tr>
                  <tr><td align="center">
                    <div style="font-size:12px;font-weight:700;color:#1A0A00;text-align:center;line-height:1.3;"><%= participant.displayName %></div>
                    <div style="font-size:10px;color:#8060B0;margin-top:3px;text-align:center;"><%= participant.role || '' %></div>
                    <% if(idx === 0) { %>
                    <div style="margin-top:6px;text-align:center;">
                      <span style="display:inline-block;background:<%= color.badge %>;border-radius:100px;padding:2px 9px;font-size:9px;font-weight:700;color:#fff;letter-spacing:.05em;">HOST</span>
                    </div>
                    <% } %>
                  </td></tr>
                </table>
              </td>
            <% } else { %>
              <td width="104" <% if(col < 4) { %>style="padding-right:6px;"<% } %>></td>
            <% } %>
          <% } %>
        </tr>
      </table>
    <% } %>

  </td></tr>
</table>
</td></tr>
<% } %>


<!-- ══════════════════════════════════════════
     NEXT STEPS
══════════════════════════════════════════ -->
<% if(nextSteps && nextSteps.length > 0) { %>
<tr><td class="a7" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:20px;overflow:hidden;border:1px solid #F0E8E0;">

  <!-- gradient top -->
  <tr><td style="background:linear-gradient(90deg,#56CFE1,#9B5DE5,#FF6B35);height:4px;font-size:1px;">&nbsp;</td></tr>

  <tr><td style="padding:28px 32px;">

    <!-- header -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:18px;">
      <tr>
        <td valign="middle">
          <div style="font-family:'Outfit',Arial,sans-serif;font-size:20px;font-weight:800;color:#1A0A00;letter-spacing:-.02em;">Next Steps</div>
        </td>
        <td align="right" valign="middle">
          <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#56CFE1,#9B5DE5);text-align:center;line-height:28px;font-family:'Outfit',Arial,sans-serif;font-size:12px;font-weight:800;color:#fff;"><%= nextSteps.length %></div>
        </td>
      </tr>
    </table>

    <!-- steps list -->
    <% nextSteps.forEach(function(step, idx) { %>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:<% if(idx === nextSteps.length - 1) { %>0<% } else { %>14px<% } %>;">
        <tr>
          <td width="36" valign="top">
            <div style="width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,#56CFE1,#9B5DE5);text-align:center;line-height:32px;font-family:'Outfit',Arial,sans-serif;font-size:13px;font-weight:800;color:#fff;"><%= idx + 1 %></div>
          </td>
          <td style="padding-left:12px;vertical-align:top;">
            <div style="font-size:13px;font-weight:600;color:#2D1810;"><% if(typeof step === 'object') { %><%= step.title %><% } else { %><%= step %><% } %></div>
            <% if(typeof step === 'object' && step.description) { %>
            <div style="font-size:12px;color:#9A7060;line-height:1.6;margin-top:4px;"><%- step.description %></div>
            <% } %>
          </td>
        </tr>
      </table>
    <% }); %>

  </td></tr>
</table>
</td></tr>
<% } %>


<!-- ══════════════════════════════════════════
     CTA — redesigned
══════════════════════════════════════════ -->
<tr><td class="a6" style="padding-top:10px;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(145deg,#FF6B35,#FF4D6D,#9B5DE5);border-radius:20px;overflow:hidden;">

  <tr><td style="padding:40px 44px;text-align:center;">

    <!-- icon circle -->
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 18px;">
      <tr><td style="width:56px;height:56px;border-radius:50%;background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.35);text-align:center;line-height:52px;font-size:26px;">📬</td></tr>
    </table>

    <div style="font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:8px;">Action Required</div>
    <div style="font-family:'Outfit',Arial,sans-serif;font-size:26px;font-weight:800;color:#fff;letter-spacing:-.02em;margin-bottom:10px;">Review & Confirm</div>
    <div style="font-size:14px;color:rgba(255,255,255,0.7);line-height:1.75;margin-bottom:28px;max-width:360px;margin-left:auto;margin-right:auto;">Please review this meeting summary and confirm your action items. Click below to view the full report.</div>

    <!-- CTA button -->
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 12px;">
      <tr><td style="background:#fff;border-radius:100px;padding:16px 44px;text-align:center;">
        <a href="<%= meetingUrl %>" style="font-family:'Outfit',Arial,sans-serif;font-size:15px;font-weight:800;color:#FF6B35;text-decoration:none;display:block;white-space:nowrap;letter-spacing:-.01em;">View Full Report →</a>
      </td></tr>
    </table>

    <!-- secondary link -->
    <div style="font-size:12px;color:rgba(255,255,255,0.4);">or reply directly to this email</div>

    <!-- divider -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:28px;">
      <tr>
        <td width="200" style="border-top:1px solid rgba(255,255,255,0.2);font-size:1px;">&nbsp;</td>
        <td align="center" style="padding:0 14px;white-space:nowrap;font-size:11px;color:rgba(255,255,255,0.4);">Next meeting coming soon</td>
        <td width="200" style="border-top:1px solid rgba(255,255,255,0.2);font-size:1px;">&nbsp;</td>
      </tr>
    </table>

  </td></tr>
</table>
</td></tr>


<!-- ══════════════════════════════════════════
     FOOTER — redesigned
══════════════════════════════════════════ -->
<tr><td style="padding-top:16px;padding-bottom:20px;" align="center">
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr><td align="center" style="padding-bottom:4px;">
      <span style="font-size:11px;color:#A09080;font-weight:500;">This is an automated meeting update — for internal use only.</span>
    </td></tr>
    <tr><td align="center" style="padding-bottom:12px;">
      <span style="font-size:10px;color:#C0AEA0;">Generated by Sumsy · Meeting Assistant · Confidential</span>
    </td></tr>
    <tr><td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0"><tr>
        <td style="padding:0 10px;"><a href="#" style="font-size:10px;font-weight:600;color:#FFA07A;text-decoration:none;letter-spacing:.1em;text-transform:uppercase;">Unsubscribe</a></td>
        <td style="font-size:10px;color:#E0C8C0;">·</td>
        <td style="padding:0 10px;"><a href="#" style="font-size:10px;font-weight:600;color:#FFA07A;text-decoration:none;letter-spacing:.1em;text-transform:uppercase;">Privacy</a></td>
        <td style="font-size:10px;color:#E0C8C0;">·</td>
