# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sumsy

# Microsoft Azure AD OAuth
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:4000/auth/callback

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AI Provider: "openai" or "anthropic"
AI_PROVIDER=openai

# OpenAI (also used for Whisper transcription)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (optional, for queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# Meeting Sync Cron (auto-syncs calendar from Microsoft Graph for all users)
MEETING_SYNC_ENABLED=true
MEETING_SYNC_CRON_INTERVAL_MS=300000
MEETING_SYNC_PAST_DAYS=7
MEETING_SYNC_FUTURE_DAYS=1

# Transcript Fetch Cron (auto-fetches transcripts + recordings after meetings end)
TRANSCRIPT_CRON_INTERVAL_MS=120000

# Email Cron (sends meeting summaries to participants)
EMAIL_ENABLED=false
EMAIL_CRON_INTERVAL_MS=60000
APP_URL=http://localhost:3000

# Azure Communication Services (Email)
ACS_CONNECTION_STRING=
ECS_SENDER_EMAIL=
